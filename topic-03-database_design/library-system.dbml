// ======================================================
// Library Management System - Topic 03 Database Design
// ======================================================
//
// Призначення:
// - architecture foundation для ER-діаграми Variant 1.
// - lightweight DBML для dbdiagram.io.
// - фокус на entities, normalization та PK/FK relationships.
// - чітке розділення між MVP tables та Final Version tables.
//
// Основні архітектурні рішення:
// - books представляє логічні сутності книг.
// - book_copies представляє фізичні екземпляри книг.
// - borrowings посилається на конкретний physical copy через copy_id.
// - authors та books пов’язані через junction table book_authors.
// - categories винесені в окрему normalized table.
// - кількість доступних книг рахується через book_copies.

// ======================================================
// TEAM RESPONSIBILITIES
// ======================================================
//
// Novikov Volodymyr - Database Architect / Team Lead
// Architecture focus:
// - overall database architecture
// - normalization
// - PK/FK relationships
// - ERD foundation
// - schema consistency
// - MVP vs Final Version separation
//
// Zhyryk Vitaliy - Inventory System
// Main table: book_copies
//
// Volodymyr Fedorkiv - Borrowing & Reservation System
// Main tables: members, borrowings, reservations
//
// Andrii Maidabura - Reviews, Testing & Documentation
// Main table: reviews

// ======================================================
// MVP BASE TABLES
// ======================================================
//
// MVP focus: basic members, logical books, and borrowing records.
// Пояснення: book_copies формально належить до Final Version, але
// borrowings повинні посилатися на конкретний physical copy через copy_id.
// Тому book_copies потрібна вже в architecture foundation для правильної
// нормалізованої ER-моделі.
// Iсторію читання вже можна отримати з borrowings: усі записи по member_id, особливо ті, де є returned_at, і будуть історією того, що людина брала раніше.
// (borrowing_status, member_id) show me active/current loans for this member
// (borrowing_status, copy_id) is this copy currently borrowed?

Table members {
  member_id bigint [pk, increment]
  first_name varchar(50)
  last_name varchar(50)
  email varchar(255)
  phone varchar(50)
  registered_at timestamp
  updated_at timestamp
}

Table books {
  book_id bigint [pk, increment]
  title varchar(255)
  isbn varchar(50)
  publication_year int
  category_id bigint


Table book_copies {
  copy_id bigserial [pk, increment]
  book_id bigint [not null, ref: > books.book_id]
  status text [not null, default: 'available', note: 'borrowed, reserved, available, lost']
  barcode text [not null, unique]
  shelf_location text [not null]
  condition text [not null, default: 'good', note: 'new, good, worn, damaged']
  acquired_date date [not null, default: `CURRENT_DATE`]
  updated_at timestamp [not null, default: `CURRENT_TIMESTAMP`]

  Indexes {
    (book_id, status) [name: 'idx_book_copies_book_status']
  }
}

Table borrowings {
  borrowing_id bigint [pk, increment]
  member_id bigint
  copy_id bigint
  borrowed_at timestamp
  due_date timestamp
  returned_at timestamp
  borrowing_status varchar(50)

  indexes {
    (borrowing_status, member_id) [name: 'idx_borrowings_status_member']
    (borrowing_status, copy_id) [name: 'idx_borrowings_status_copy']
  }
}

// ======================================================
// NORMALIZATION SUPPORT TABLES
// ======================================================
//
// Ці таблиці запобігають дублюванню author та category data в books.

Table categories {
  category_id bigint [pk, increment]
  category_name varchar(100)
}

Table authors {
  author_id bigint [pk, increment]
  first_name varchar(100)
  last_name varchar(100)
}

Table book_authors {
  book_id bigint
  author_id bigint

  indexes {
    (book_id, author_id) [pk]
  }
}

// ======================================================
// FINAL VERSION EXTENSION TABLES
// ======================================================
//
// Ці сутності розширюють базову модель. Детальні правила та робочі процеси
// залишаються поза межами цієї архітектурної основи.

Table reservations {
  reservation_id bigint [pk, increment]
  member_id bigint
  book_id bigint
  reservation_date timestamp
  reservation_status varchar(50)
}

Table reviews {
  review_id bigint [pk, increment]
  member_id bigint
  book_id bigint
  rating int
  review_text text
  created_at timestamp

  indexes {
    (member_id, rating, review_text)
  }
}

// ======================================================
// RELATIONSHIPS
// ======================================================

Ref: books.category_id > categories.category_id

Ref: book_copies.book_id > books.book_id

Ref: borrowings.member_id > members.member_id
Ref: borrowings.copy_id > book_copies.copy_id

Ref: book_authors.book_id > books.book_id
Ref: book_authors.author_id > authors.author_id

Ref: reservations.member_id > members.member_id
Ref: reservations.book_id > books.book_id

Ref: reviews.member_id > members.member_id
Ref: reviews.book_id > books.book_id
